{
  "$schema": "https://json-schema.org/draft/2020-12/schema", 
  "type": "object", 
  "required": [ "control",  "files",  "meta" ], 
  "properties": {
    "control": {
      "type": "object", 
      "properties": {
        "conflicts": {
          "type": "string"
        }, 
        "depends": {
          "type": "string"
        }, 
        "description": {
          "type": "string", 
          "minLength": "1"
        }, 
        "homepage": {
          "type": "string"
        }, 
        "installedSize": {
          "type": "integer"
        }, 
        "maintainer": {
          "type": "string", 
          "minLength": "1"
        }, 
        "priority": {
          "type": "string", 
          "minLength": "1"
        }, 
        "recommends": {
          "type": "string"
        }, 
        "section": {
          "type": "string", 
          "minLength": "1"
        }
      }, 
      "required": [ "conflicts",  "depends",  "description",  "homepage",  "maintainer",  "priority",  "recommends",  "section" ]
    }, 
    "files": {
      "type": "object", 
      "properties": {
        "controlFiles": {
          "type": "array", 
          "items": {
            "$ref": "#/$defs/TarFileSpec"
          }
        }, 
        "dataFiles": {
          "type": "array", 
          "items": {
            "$ref": "#/$defs/TarFileSpec"
          }
        }
      }, 
      "required": [ "controlFiles",  "dataFiles" ]
    }, 
    "meta": {
      "type": "object", 
      "properties": {
        "arch": {
          "type": "string", 
          "enum": [ "amd64",  "arm64",  "armhf",  "riscv64",  "all" ]
        }, 
        "name": {
          "type": "string", 
          "minLength": "1"
        }, 
        "version": {
          "type": "string", 
          "minLength": "1"
        }
      }, 
      "required": [ "arch",  "name",  "version" ]
    }
  }, 
  "$defs": {
    "BinaryTarFileSpec": {
      "type": "object", 
      "properties": {
        "content": {
          "minItems": "1", 
          "type": "array", 
          "items": {
            "type": "string"
          }
        }, 
        "mode": {
          "type": "integer"
        }, 
        "path": {
          "type": "string", 
          "minLength": "1"
        }, 
        "type": {
          "const": "binary"
        }
      }, 
      "required": [ "content",  "path",  "type" ]
    }, 
    "DirTarFileSpec": {
      "type": "object", 
      "properties": {
        "mode": {
          "type": "integer"
        }, 
        "modeMode": {
          "type": "string", 
          "enum": [ "INHERIT",  "OVERRIDE" ]
        }, 
        "modeOverrides": {
          "type": "object", 
          "additionalProperties": {
            "type": "integer"
          }
        }, 
        "path": {
          "type": "string", 
          "minLength": "1"
        }, 
        "sourcePath": {
          "type": "string", 
          "minLength": "1"
        }, 
        "type": {
          "const": "dir"
        }
      }, 
      "required": [ "modeMode",  "path",  "sourcePath",  "type" ]
    }, 
    "FileTarFileSpec": {
      "type": "object", 
      "properties": {
        "mode": {
          "type": "integer"
        }, 
        "path": {
          "type": "string", 
          "minLength": "1"
        }, 
        "sourcePath": {
          "type": "string", 
          "minLength": "1"
        }, 
        "type": {
          "const": "file"
        }
      }, 
      "required": [ "path",  "sourcePath",  "type" ]
    }, 
    "S3ObjectTarFileSpec": {
      "type": "object", 
      "properties": {
        "mode": {
          "type": "integer"
        }, 
        "path": {
          "type": "string", 
          "minLength": "1"
        }, 
        "region": {
          "type": "string"
        }, 
        "s3Url": {
          "type": "string", 
          "format": "uri"
        }, 
        "type": {
          "const": "s3"
        }
      }, 
      "required": [ "path",  "s3Url",  "type" ]
    }, 
    "S3ZipArchiveTarFileSpec": {
      "type": "object", 
      "properties": {
        "mode": {
          "type": "integer"
        }, 
        "path": {
          "type": "string", 
          "minLength": "1"
        }, 
        "region": {
          "type": "string"
        }, 
        "s3Url": {
          "type": "string", 
          "format": "uri"
        }, 
        "zipPath": {
          "type": "string"
        }, 
        "type": {
          "const": "s3zip"
        }
      }, 
      "required": [ "path",  "s3Url",  "zipPath",  "type" ]
    }, 
    "TarFileSpec": {
      "anyOf": [ {
        "$ref": "#/$defs/TextTarFileSpec"
      },  {
        "$ref": "#/$defs/BinaryTarFileSpec"
      },  {
        "$ref": "#/$defs/FileTarFileSpec"
      },  {
        "$ref": "#/$defs/DirTarFileSpec"
      },  {
        "$ref": "#/$defs/UrlTarFileSpec"
      },  {
        "$ref": "#/$defs/S3ObjectTarFileSpec"
      },  {
        "$ref": "#/$defs/S3ZipArchiveTarFileSpec"
      } ]
    }, 
    "TextTarFileSpec": {
      "type": "object", 
      "properties": {
        "content": {
          "type": "string", 
          "minLength": "1"
        }, 
        "mode": {
          "type": "integer"
        }, 
        "path": {
          "type": "string", 
          "minLength": "1"
        }, 
        "type": {
          "const": "text"
        }
      }, 
      "required": [ "content",  "path",  "type" ]
    }, 
    "UrlTarFileSpec": {
      "type": "object", 
      "properties": {
        "bearerToken": {
          "type": "string"
        }, 
        "headers": {
          "type": "object", 
          "additionalProperties": {
            "type": "array", 
            "items": {
              "type": "string"
            }
          }
        }, 
        "mode": {
          "type": "integer"
        }, 
        "path": {
          "type": "string", 
          "minLength": "1"
        }, 
        "url": {
          "type": "string", 
          "format": "uri"
        }, 
        "type": {
          "const": "url"
        }
      }, 
      "required": [ "path",  "url",  "type" ]
    }
  }
}